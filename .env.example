# Copy to .env and adjust as needed. The scraper and classifier read these.
MONGODB_URI=mongodb://localhost:27017
MONGO_DB_NAME=byu_police_beat

# Local Ollama model used by the classifier's LLM fallback.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# PostgreSQL clean store (serving layer + dbt target).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=byu_police_beat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
